{
  "name": "uptest-v2",
  "private": true,
  "version": "0.0.0",
  "main": "electron/main.js",
  "type": "module",
  "scripts": {
    "start": "npm run build && electron .",
    "web": "npm run build:core && npm run dev --prefix packages/ui",
    "dev": "npm run build:core && concurrently \"npm run dev:ui\" \"wait-on http://localhost:5173 && electron .\"",
    "dev:ui": "npm run dev --prefix packages/ui",
    "dev:electron": "electron .",
    "build": "npm run build --prefix packages/core && npm run build --prefix packages/ui",
    "build:core": "npm run build --prefix packages/core",
    "build:ui": "npm run build --prefix packages/ui",
    "lint": "eslint .",
    "preview": "npm run preview --prefix packages/ui"
  },
  "dependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/node": "^24.10.1",
    "concurrently": "^9.2.1",
    "electron": "^40.7.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "wait-on": "^9.0.4"
  }
}
